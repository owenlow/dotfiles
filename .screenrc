# change the hardstatus settings to give an window list at the bottom
# of the screen, with the time and date and with the current window highlighted                                                                                                              
startup_message off                                                                                                      
hardstatus alwayslastline

#hardstatus string '%{= kG}%-Lw%{= kW}%50> %n%f* %t%{=kG}%+Lw%< %{= kG}%-=%c:%s%{-}'                                    
hardstatus string '%{= kG}[%= %{= kw}%?%-Lw%?%{r}(%{W}%n*%f%t%?(%u)%?%{r})%{w}%?%+Lw%?%?%= %{g}][%{B} %m-%d %{W}%c %{g}]'                                                                                                         

# Arrow keys to switch terminals (only works with X)                                                                     
# Alt + left                                                                                                             
bindkey ^[[1;3D prev                                                                                                     
# Alt + right                                                                                                            
bindkey ^[[1;3C next                                                                                                     
